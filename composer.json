{
    "name": "antigravity/whatsapp-backend",
    "description": "Production-Grade Backend API for a WhatsApp-Like Android Chat Application",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "cboden/ratchet": "^0.4.4",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": true,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
