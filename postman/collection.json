{
	"info": {
		"_postman_id": "8b51d8b9-a299-4d6b-b0b2-9d39eaee52ee",
		"name": "WhatsApp Backend API",
		"description": "Postman Collection for testing the WhatsApp-like Android chat app backend API.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Generate OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"mobile_number\": \"+919876543210\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/otp/generate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"otp",
								"generate"
							]
						}
					}
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"mobile_number\": \"+919876543210\",\n    \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/otp/verify",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"otp",
								"verify"
							]
						}
					}
				}
			]
		},
		{
			"name": "Sync & Chat",
			"item": [
				{
					"name": "Synchronize Contacts",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"contacts\": [\n        {\n            \"name\": \"Alice\",\n            \"phone\": \"+19876543210\"\n        },\n        \"+10000000001\"\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/contact/sync",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"contact",
								"sync"
							]
						}
					}
				},
				{
					"name": "Start Conversation",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiver_phone\": \"+19876543210\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/chat/start",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"chat",
								"start"
							]
						}
					}
				},
				{
					"name": "Incremental Sync",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sync_items\": [\n        {\n            \"conversation_id\": \"33333333-3333-4333-8333-333333333333\",\n            \"last_message_id\": 0\n        }\n    ],\n    \"last_sync_time\": \"\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/chat/sync",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"chat",
								"sync"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "access_token",
			"value": "your_jwt_access_token_here"
		}
	]
}
