# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=whatsapp_db
DB_USERNAME=root
DB_PASSWORD=

# JWT Secrets (use high-entropy random strings)
JWT_SECRET=your_jwt_access_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me
JWT_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=2592000

# Fast2SMS WhatsApp API Configuration
# API URL: https://www.fast2sms.com/dev/whatsapp
FAST2SMS_API_KEY=your_fast2sms_api_key_here
FAST2SMS_PHONE_NUMBER_ID=your_phone_number_id
FAST2SMS_MESSAGE_ID=your_message_id

# Firebase Cloud Messaging
FCM_PROJECT_ID=your_fcm_project_id
FCM_CREDENTIALS_PATH=config/firebase_credentials.json

# Redis Configuration (Optional, fallback to DB if empty)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# WebSocket Configuration
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8080

# Media Upload Configuration
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE_MB=50
